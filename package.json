{
  "name": "paac",
  "version": "1.0.0",
  "description": "",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "bin": {
    "paac": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env --import tsx src/cli.ts",
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=html",
    "test:e2e": "pnpm build && node --env-file=.env.daytona ./node_modules/vitest/vitest.mjs run -c vitest.e2e.config.ts",
    "test:e2e:reuse": "PAAC_E2E_REUSE_SANDBOX=1 pnpm test:e2e",
    "polar:e2e:snapshot": "node --env-file=.env.daytona --import tsx scripts/polar-daytona-create-snapshot.ts --write-config",
    "polar:e2e:up": "node --env-file=.env.daytona --import tsx scripts/polar-daytona-up.ts",
    "lint": "oxlint -c .oxlintrc.ts",
    "format": "oxfmt -c .oxfmtrc.ts --write .",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "4.0.0-beta.76",
    "@polar-sh/sdk": "^0.47.1",
    "@vitest/coverage-v8": "^4.1.8",
    "effect": "4.0.0-beta.76"
  },
  "devDependencies": {
    "@daytona/sdk": "^0.184.0",
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "4.0.0-beta.78",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "7.0.0-dev.20260603.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
